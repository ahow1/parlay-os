# ── Required ──────────────────────────────────────────────────────────────────
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (get it from @userinfobot)
TELEGRAM_CHAT_ID=

# Separate chat for system health alerts (can be same as CHAT_ID)
TELEGRAM_ALERT_CHAT_ID=

# The Odds API key — https://the-odds-api.com
ODDS_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Backup Odds API key (used automatically if primary hits quota)
ODDS_API_KEY_BACKUP=

# SQLite database path (default: parlay_os.db in working directory)
PARLAY_DB=parlay_os.db
