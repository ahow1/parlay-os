# ── Required ──────────────────────────────────────────────────────────────────
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token

# Your Telegram chat ID (get it from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id

# Separate chat for system health alerts (can be same as CHAT_ID)
TELEGRAM_ALERT_CHAT_ID=your_alert_channel_id

# The Odds API key — https://the-odds-api.com
ODDS_API_KEY=your_primary_key

# ── Optional ──────────────────────────────────────────────────────────────────
# Backup Odds API key (auto-switched if primary hits 429/401 quota)
ODDS_API_KEY_BACKUP=your_backup_key

# Flask port (Railway sets this automatically; default 5000 locally)
PORT=5000

# SQLite database path (default: parlay_os.db in working directory)
PARLAY_DB=parlay_os.db
